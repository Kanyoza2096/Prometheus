# Environment Variables
VITE_SUPABASE_URL=your-supabase-url-here
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Connection Settings (WebSocket, REST APIs, Master Token)
VITE_WS_ENDPOINT=wss://your-backend-websocket-url
VITE_REST_ENDPOINT=https://your-backend-rest-url/api/v1
VITE_MASTER_TOKEN=your-master-access-token
